# Copie para .env e preencha. NUNCA commite o .env (ja esta no .gitignore).

# === Obrigatorios ===
GCP_PROJECT_ID=meu-projeto-gcp
BQ_DATASET=meu-dataset-gcp

# === Opcionais (defaults aplicados se omitidos) ===
# GCP_REGION=us-central1
# BQ_LOCATION=US
# DBT_THREADS=8

# Pasta do projeto dbt no repo (onde fica o dbt_project.yml)
# DBT_PROJECT_DIR=ManutBR

# Nomes dos recursos criados no GCP
# ARTIFACT_REPO=manutbr
# IMAGE_NAME=manutbr-dbt
# JOB_NAME=manutbr-dbt-job
# SERVICE_ACCOUNT_NAME=dbt-runner
# IMAGE_TAG=latest
